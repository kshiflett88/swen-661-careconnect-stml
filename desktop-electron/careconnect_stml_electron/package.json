{
  "name": "desktop-electron",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "CareConnect STML desktop application built with Electron and React.",
  "author": "CareConnect Team",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "vite": "vite",
    "electron": "electron .",
    "dev": "concurrently -k \"npm run vite\" \"npm run build:electron:watch\" \"wait-on http://localhost:4173 && npm run build:electron && npm run electron\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"const fs=require('fs');['main','preload'].forEach(f=>{const src='dist-electron/'+f+'.js';const dst='dist-electron/'+f+'.cjs';if(fs.existsSync(src)){fs.renameSync(src,dst);}});\"",
    "build:electron:watch": "tsc -p tsconfig.electron.json --watch",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis --publish never -c.win.signAndEditExecutable=false",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:unit:watch": "jest --config jest.config.cjs --watch",
    "test:a11y": "jest --config jest.config.cjs src/__tests__/Accessibility.automated.test.tsx",
    "test:e2e": "playwright test",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.51.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^25.0.1",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "edu.swen661.careconnect.desktop",
    "productName": "CareConnect STML",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
